# Root Docker example env values

# evenstocks-api
DB_HOST=mysql
DB_USER=root
DB_PASSWORD=example
SENDER_EMAIL=info@evenstocks.com
SENDER_PASSWORD=changeme
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# evenstocks-chatbot
ANTHROPIC_API_KEY=your_anthropic_api_key
MODEL=claude-sonnet-4-20250514
MAX_TOKENS=2048

# evenstocks-backend
EXTERNAL_API_BASE=http://evenstocks-api:5809/api
ANALYZE_API_BASE=http://evenstocks-analyze:5808

# frontend (React)
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_CHATBOT_WS_URL=ws://localhost:8000

# frontend (React)
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_CHATBOT_WS_URL=ws://localhost:8000
